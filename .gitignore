# ============================================================
# BRAINIAC — .gitignore
# ============================================================

# --- Credenciais e tokens OAuth (NUNCA subir) ---
credentials.json
token.json
*.json.bak
.env
.env.*

# --- Config local gerado em runtime ---
brainiac_config.json

# --- Dados gerados em runtime (textos extraídos e metadados) ---
brainiac_txt/
brainiac_mgmt/
cerebro_txt/
gestao_local/

# --- Backup local (não vai pro git, mas mantém no disco) ---
_backup_local/

# --- Build / Distribuição (PyInstaller) ---
build/
dist/
output/

# --- Pacotes e binários ---
*.zip
*.exe

# --- Node / Frontend ---
web_interface/node_modules/
web_interface/.vite/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# --- Ambientes virtuais ---
.venv
venv/
env/
ENV/

# --- IDEs ---
.vscode/
.idea/
*.suo
*.user

# --- OS ---
.DS_Store
Thumbs.db