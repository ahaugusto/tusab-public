# ============================================================
# BRAINIAC — .gitignore
# ============================================================

# --- Credenciais e tokens OAuth (NUNCA subir) ---
credentials.json
data/config/token.json
data/config/agent_config.json
*.json.bak
.env
.env.*

# --- Dados gerados em runtime ---
data/cerebro_txt/
data/gestao/
data/agent_index/
data/temp/

# --- Legado (caminhos antigos) ---
cerebro_txt/
gestao_local/
brainiac_txt/
brainiac_mgmt/

# --- Backup local (não vai pro git, mas mantém no disco) ---
_backup_local/

# --- Build / Distribuição (PyInstaller) ---
build/
dist/
output/

# --- Pacotes e binários ---
*.zip
*.exe

# --- Node / Frontend ---
web_interface/node_modules/
web_interface/.vite/

# --- Electron ---
electron/node_modules/
electron/python_env/
electron/bin/
electron/build_resources/*.bmp
electron/build_resources/*.ico
dist_electron/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# --- Ambientes virtuais ---
.venv
venv/
env/
ENV/

# --- IDEs ---
.vscode/
.idea/
*.suo
*.user

# --- OS ---
.DS_Store
Thumbs.db